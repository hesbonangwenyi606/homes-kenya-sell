# Supabase — get these from your Supabase project dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Settings > API > service_role (NEVER expose to browser)

# Server
PORT=3001

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8080

# Admin — comma-separated list of Supabase user emails with admin access
# These users must already exist in Supabase Auth (sign them up first)
ADMIN_EMAILS=admin@yourdomain.com
